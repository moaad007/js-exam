# Environment variables for the backend

# Use your provider's transaction-pooled connection string for DATABASE_URL.
# Supabase: port 6543 + ?pgbouncer=true. Neon: the pooled URL. Clever Cloud:
# the single endpoint with ?pgbouncer=true (no separate pooled port).
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DB?pgbouncer=true&connection_limit=2&pool_timeout=10&connect_timeout=10"

# Direct (non-pooled) connection used by `prisma migrate deploy` / `prisma db push`.
DIRECT_URL="postgresql://USER:PASS@HOST:PORT/DB"

# Server port
PORT=4000

# Frontend URL for CORS
CLIENT_URL="http://localhost:3000"

# JWT secret (change this in production)
JWT_SECRET="change-this-secret-in-production"
